APP_NAME="DWAI Studio"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=/root/.openclaw/workspace/dwai-studio-laravel/database/database.sqlite

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMORY_LIMIT=256M
MAX_EXECUTION_TIME=300

PHP_CLI_ARGS="--no-warnings"

# ============================================================
# AI Configuration
# ============================================================

# Local only mode (recommended for development)
AI_LOCAL_ONLY=true

# Default provider
AI_PROVIDER=mock

# Feature-specific providers (can mix different backends)
AI_TEXT_PROVIDER=mock
AI_IMAGE_PROVIDER=mock
AI_STORYBOARD_PROVIDER=mock

# ============================================================
# External Providers (enable when ready)
# ============================================================

# OpenAI (Text)
# OPENAI_ENABLED=false
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_TEXT_MODEL=gpt-4

# Anthropic (Text)
# ANTHROPIC_ENABLED=false
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-3-opus-20240229

# Replicate (Image)
# REPLICATE_ENABLED=false
# REPLICATE_API_TOKEN=your-token

# Stability AI (Image)
# STABILITY_ENABLED=false
# STABILITY_API_KEY=your-key
