APP_NAME="DWAI Studio"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=/root/.openclaw/workspace/dwai-studio-laravel/database/database.sqlite

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMORY_LIMIT=256M
MAX_EXECUTION_TIME=300

PHP_CLI_ARGS="--no-warnings"
