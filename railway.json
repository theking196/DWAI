{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "buildCommand": "composer install --ignore-platform-reqs --optimize-autoloader",
    "installCommand": "composer install --ignore-platform-reqs --optimize-autoloader"
  },
  "start": {
    "command": "php artisan migrate --force || true && php-fpm"
  },
  "deploy": {
    "numReplicas": 1
  }
}
